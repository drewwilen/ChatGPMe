# ChatGPMe Configuration (.env template)
# Copy to .env and customize as needed

# Model Configuration
CHATGPME_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
CHATGPME_ADAPTER=artifacts/tinyllama-style-lora-mvp
CHATGPME_DEVICE=auto  # "auto", "cuda", or "cpu"

# Server Configuration
CHATGPME_HOST=127.0.0.1
CHATGPME_PORT=8000
CHATGPME_DEBUG=false
# For remote inference, uncomment and set:
# CHATGPME_REMOTE_API=http://localhost:9000

# Evaluation Configuration
CHATGPME_EVAL_MODEL=gpt-4o-mini
# Set your API keys here:
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Logging
CHATGPME_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
